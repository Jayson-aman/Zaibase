# Google Cloud Text-to-Speech API
# Standard voices: $4/million characters（最安値）
# https://console.cloud.google.com/ でAPIキーを発行してください
EXPO_PUBLIC_GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# RevenueCat APIキー（https://app.revenuecat.com でアプリ追加後に取得）
# RevenueCatのアプリ: 宅建士対策 by Zaibase  bundleID: com.zaibase.takken
# App Store Connect で商品IDを作成: com.zaibase.takken.pro.monthly / com.zaibase.takken.max.monthly
EXPO_PUBLIC_RC_API_KEY_IOS=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_RC_API_KEY_ANDROID=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
