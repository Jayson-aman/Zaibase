# Gemini API（Nano Banana Pro / Flash Image で歴史イラスト生成）
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# RevenueCat（App Store / Google Play 課金）
EXPO_PUBLIC_RC_API_KEY_IOS=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase（AIコーチ用 Cloud Functions の呼び出し。値はFirebaseコンソール→プロジェクトの設定→ウェブアプリ から取得）
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# App Check（Web版のみ。reCAPTCHA v3サイトキー。Firebaseコンソール→App Check で発行）
EXPO_PUBLIC_FIREBASE_RECAPTCHA_SITE_KEY=
