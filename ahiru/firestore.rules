rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── AIコーチ利用回数カウンタ（Cloud Functions専用、クライアントから読み書き不可） ──
    match /aiCoachUsage/{uid} {
      allow read, write: if false;
    }

    // ── AI個別指導（Cloud Functions専用） ──
    match /aiTutorUsage/{uid} {
      allow read, write: if false;
    }

    match /aiTutorSessions/{docId} {
      allow read, write: if false;
    }
  }
}
